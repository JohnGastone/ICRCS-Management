{
  "info": {
    "_postman_id": "07ec2613-7e93-489f-aad4-ddc364031d84",
    "name": "ICRCS Management — Assessment & Approval",
    "description": "Base URL: http://10.232.0.12:8081/api\n\n== Auth ==\nAll requests require a Bearer token from the User Management API.\nSet {{officer_token}} before running.\n\n== Workflow ==\n1. Stage 9 completes in icrcs-api → CaseAssignment auto-created (PENDING_ENROLLMENT)\n2. POST /init — manually create a case if needed\n3. POST /assign — assign case to an assessor\n4. POST /enroll — mock biometric (PENDING_ENROLLMENT → PENDING_ASSESSMENT)\n5. POST /start-assessment — assessor opens case (PENDING_ASSESSMENT → UNDER_ASSESSMENT)\n6. POST /assess — submit recommendation (→ ASSESSMENT_COMPLETE)\n7. POST /decide — approver submits final decision\n\n== Status flow ==\nPENDING_ENROLLMENT → PENDING_ASSESSMENT → UNDER_ASSESSMENT → ASSESSMENT_COMPLETE → APPROVED | REJECTED | ESCALATED\n\nAuto-set variables: case_no",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "40697580"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.code === 1 && res.data) {",
                  "    pm.collectionVariables.set('officer_token', res.data.access_token);",
                  "    pm.collectionVariables.set('refresh_token', res.data.refresh_token);",
                  "    console.log('officer_token saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"christian.mwachiluwi@immigration.go.tz\",\n    \"password\": \"your_password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "auth",
                "login"
              ]
            },
            "description": "Login with officer credentials.\nAuto-saves {{officer_token}} and {{refresh_token}}.\nNo Bearer token needed for this request."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.code === 1 && res.data) {",
                  "    pm.collectionVariables.set('officer_token', res.data.access_token);",
                  "    pm.collectionVariables.set('refresh_token', res.data.refresh_token);",
                  "    console.log('tokens rotated');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/auth/refresh",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "auth",
                "refresh"
              ]
            },
            "description": "Refresh expired access token.\nAuto-saves new {{officer_token}} and {{refresh_token}}."
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/auth/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "auth",
                "logout"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Desk (Enrollment)",
      "item": [
        {
          "name": "Enrollment Queue",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/v1/management/cases/enrollment?page=0&size=20",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "management",
                "cases",
                "enrollment"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "20"
                },
                {
                  "key": "search",
                  "value": "",
                  "disabled": true
                }
              ]
            },
            "description": "Walk-in queue — all cases in PENDING_ENROLLMENT status, ordered oldest first (FIFO).\nDesk officer uses this to see who is waiting for biometric enrollment.\nOptional: search by caseNo or subjectId."
          },
          "response": []
        },
        {
          "name": "Lookup by SubjectId",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.caseNo) {",
                  "    pm.collectionVariables.set('case_no', res.data.caseNo);",
                  "    console.log('case_no set to', res.data.caseNo);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/v1/management/cases/by-subject/{{subject_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "management",
                "cases",
                "by-subject",
                "{{subject_id}}"
              ]
            },
            "description": "Officer enters the applicant's subjectId → returns full case detail regardless of status.\nAlso auto-saves {{case_no}} so subsequent requests (enroll, assign, etc.) work immediately.\n\nThis is the first step when an applicant walks in and hands over their subjectId."
          },
          "response": []
        },
        {
          "name": "New Request",
          "request": {
            "method": "GET",
            "header": [],
